def predict_video(model, video_path, n_frames=40):
    cap = cv2.VideoCapture(video_path)
    total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    indices = np.linspace(0, total - 1, n_frames, dtype=int)
    
    frame_preds = []
    frame_probs = []
    
    for idx in indices:
        cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
        ret, frame = cap.read()
        if not ret:
            continue
        frame = cv2.resize(frame, (224, 224))
        frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        image_np = np.array(frame)
        tensor = video_val_tfms(image=image_np)["image"].unsqueeze(0).to(DEVICE)
        with torch.no_grad():
            with torch.amp.autocast(device_type="cuda", enabled=USE_AMP):
                logit = model_ev_vid(tensor)
        prob = torch.sigmoid(logit).item()
        frame_preds.append(1 if prob >= 0.5 else 0)
        frame_probs.append(prob)
    
    cap.release()
    
    avg_prob    = np.mean(frame_probs)
    vote        = "Real" if np.mean(frame_preds) >= 0.5 else "Fake"
    confidence  = avg_prob if avg_prob >= 0.5 else 1 - avg_prob
    return vote, confidence, frame_probs

