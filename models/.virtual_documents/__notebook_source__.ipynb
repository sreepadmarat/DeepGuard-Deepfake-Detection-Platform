class DeepfakeDataset(Dataset):
    def __init__(self, root, transform):
        self.inner = datasets.ImageFolder(root=str(root))
        self.samples = self.inner.samples
        self.targets = [s[1] for s in self.samples]
        self.transform = transform

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        path, label = self.samples[idx]
        image = np.array(Image.open(path).convert("RGB"))
        augmented = self.transform(image=image)["image"]
        return augmented, label


def build_loaders(train_size, val_size, mean, std):
    train_tfms = A.Compose([
        A.Resize(train_size, train_size),
        A.HorizontalFlip(p=0.5),
        A.ColorJitter(brightness=0.15, contrast=0.15, saturation=0.1, hue=0.02, p=0.75),
        A.Affine(translate_percent=0.02, scale=0.1, rotate=10, p=0.5),
        A.Normalize(mean=mean, std=std),
        ToTensorV2()
    ])
    val_tfms = A.Compose([
        A.Resize(val_size, val_size),
        A.Normalize(mean=mean, std=std),
        ToTensorV2()
    ])

    train_ds = DeepfakeDataset(DATA_ROOT / "Train", train_tfms)
    val_ds   = DeepfakeDataset(DATA_ROOT / "Validation", val_tfms)
    test_ds  = DeepfakeDataset(DATA_ROOT / "Test", val_tfms)

    train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,  num_workers=2, pin_memory=True)
    val_loader   = DataLoader(val_ds,   batch_size=BATCH_SIZE, shuffle=False, num_workers=2, pin_memory=True)
    test_loader  = DataLoader(test_ds,  batch_size=BATCH_SIZE, shuffle=False, num_workers=2, pin_memory=True)

    labels = np.array(train_ds.targets)
    num_pos = max(1, int((labels == 1).sum()))
    num_neg = max(1, int((labels == 0).sum()))
    pos_weight = torch.tensor([float(num_neg) / float(num_pos)], dtype=torch.float32).to(DEVICE)

    return train_loader, val_loader, test_loader, pos_weight


