def get_top_frames(model, video_path, label_dir, n_frames=40, top_n=5):
    cap = cv2.VideoCapture(video_path)
    total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    indices = np.linspace(0, total - 1, n_frames, dtype=int)
    
    frame_data = []
    for idx in indices:
        cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
        ret, frame = cap.read()
        if not ret:
            continue
        frame = cv2.resize(frame, (224, 224))
        frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        image_np = frame_rgb.astype(np.float32)
        tensor = video_val_tfms(image=frame_rgb)["image"].unsqueeze(0).to(DEVICE)
        with torch.no_grad():
            with torch.amp.autocast(device_type="cuda", enabled=USE_AMP):
                logit = model_ev_vid2(tensor)
        prob = torch.sigmoid(logit).item()
        frame_data.append((frame_rgb, prob, idx))
    cap.release()
    
    frame_data.sort(key=lambda x: abs(x[1] - 0.5), reverse=True)
    return frame_data[:top_n]

