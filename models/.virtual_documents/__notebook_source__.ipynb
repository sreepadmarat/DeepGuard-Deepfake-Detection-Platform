    true_label   = "Fake" if "Fake" in str(path) else "Real"
    ev_label, ev_conf = predict_image(model_ev_pred, path)
    mn_label, mn_conf = predict_image(model_mn_pred, path)

    img = Image.open(path).convert("RGB")
    axes[i].imshow(img)
    axes[i].axis("off")

    ev_correct = "✓" if ev_label == true_label else "✗"
    mn_correct = "✓" if mn_label == true_label else "✗"

    title_color = "#1a1a1a"
    axes[i].set_title(
        f"True: {true_label}\n"
        f"EViT: {ev_label} ({ev_conf:.2f}) {ev_correct}\n"
        f"MNV3: {mn_label} ({mn_conf:.2f}) {mn_correct}",
