def train_one_epoch(model, loader, optimizer, scaler, loss_fn):
    model.train()
    running_loss = 0.0
    all_probs, all_targets = [], []

    for images, labels in tqdm(loader, desc="Training", leave=False):
        images = images.to(DEVICE, non_blocking=True)
        targets = labels.float().unsqueeze(1).to(DEVICE, non_blocking=True)

        optimizer.zero_grad(set_to_none=True)
        with torch.amp.autocast(device_type="cuda", enabled=USE_AMP):
            logits = model(images)
            loss = loss_fn(logits, targets)

        scaler.scale(loss).backward()
        scaler.step(optimizer)
        scaler.update()

        running_loss += loss.item() * images.size(0)
        all_probs.append(torch.sigmoid(logits.detach()).cpu().numpy())
        all_targets.append(targets.detach().cpu().numpy())

    y_prob = np.concatenate(all_probs)
    y_true = np.concatenate(all_targets)
    preds  = (y_prob >= 0.5).astype(int)
    tp = int(np.sum((preds == 1) & (y_true == 1)))
    fp = int(np.sum((preds == 1) & (y_true == 0)))
    fn = int(np.sum((preds == 0) & (y_true == 1)))
    tn = int(np.sum((preds == 0) & (y_true == 0)))
    recall      = tp / max(1, tp + fn)
    precision   = tp / max(1, tp + fp)
    specificity = tn / max(1, tn + fp)
    f1          = 2 * precision * recall / max(1e-12, precision + recall)
    acc         = (tp + tn) / max(1, tp + fp + fn + tn)
    return running_loss / len(loader.dataset), {"acc": acc, "f1": f1, "precision": precision, "recall": recall}


def evaluate(model, loader, loss_fn):
    model.eval()
    running_loss = 0.0
    all_probs, all_targets = [], []

    with torch.no_grad():
        for images, labels in tqdm(loader, desc="Evaluating", leave=False):
            images  = images.to(DEVICE, non_blocking=True)
            targets = labels.float().unsqueeze(1).to(DEVICE, non_blocking=True)
            with torch.amp.autocast(device_type="cuda", enabled=USE_AMP):
                logits = model(images)
                loss   = loss_fn(logits, targets)
            running_loss += loss.item() * images.size(0)
            all_probs.append(torch.sigmoid(logits).cpu().numpy())
            all_targets.append(targets.cpu().numpy())

    y_prob = np.concatenate(all_probs)
    y_true = np.concatenate(all_targets)
    preds  = (y_prob >= 0.5).astype(int)
    tp = int(np.sum((preds == 1) & (y_true == 1)))
    fp = int(np.sum((preds == 1) & (y_true == 0)))
    fn = int(np.sum((preds == 0) & (y_true == 1)))
    tn = int(np.sum((preds == 0) & (y_true == 0)))
    recall      = tp / max(1, tp + fn)
    precision   = tp / max(1, tp + fp)
    specificity = tn / max(1, tn + fp)
    f1          = 2 * precision * recall / max(1e-12, precision + recall)
    acc         = (tp + tn) / max(1, tp + fp + fn + tn)
    return running_loss / len(loader.dataset), {"acc": acc, "f1": f1, "precision": precision, "recall": recall}, y_true.flatten(), y_prob.flatten()


def plot_training_curves(history, model_name, color_train, color_val):
    epochs_range = range(1, len(history["train_loss"]) + 1)
    fig, axes = plt.subplots(1, 2, figsize=(13, 4))
    axes[0].plot(epochs_range, history["train_loss"], color=color_train, linewidth=2, marker="o", label="Train Loss")
    axes[0].plot(epochs_range, history["val_loss"],   color=color_val,   linewidth=2, marker="s", label="Val Loss", linestyle="--")
    axes[0].set_title(f"{model_name} — Loss", fontweight="bold")
    axes[0].set_xlabel("Epoch")
    axes[0].set_ylabel("Loss")
    axes[0].legend()
    axes[0].spines[["top","right"]].set_visible(False)

    axes[1].plot(epochs_range, history["train_f1"], color=color_train, linewidth=2, marker="o", label="Train F1")
    axes[1].plot(epochs_range, history["val_f1"],   color=color_val,   linewidth=2, marker="s", label="Val F1", linestyle="--")
    axes[1].set_title(f"{model_name} — F1 Score", fontweight="bold")
    axes[1].set_xlabel("Epoch")
    axes[1].set_ylabel("F1")
    axes[1].legend()
    axes[1].spines[["top","right"]].set_visible(False)

    plt.suptitle(f"{model_name} Training Curves", fontsize=14, fontweight="bold")
    plt.tight_layout()
    plt.savefig(f"{model_name.lower().replace(' ','_')}_curves.png", dpi=120, bbox_inches="tight")
    plt.show()


def plot_confusion_matrix(y_true, y_prob, model_name, cmap_color):
    preds = (y_prob >= 0.5).astype(int)
    cm = np.array([[np.sum((preds==0)&(y_true==0)), np.sum((preds==1)&(y_true==0))],
                   [np.sum((preds==0)&(y_true==1)), np.sum((preds==1)&(y_true==1))]])
    fig, ax = plt.subplots(figsize=(5, 4))
    sns.heatmap(cm, annot=True, fmt="d", cmap=cmap_color, xticklabels=["Real","Fake"], yticklabels=["Real","Fake"], ax=ax, linewidths=0.5)
    ax.set_xlabel("Predicted", fontsize=11)
    ax.set_ylabel("Actual", fontsize=11)
    ax.set_title(f"{model_name} — Confusion Matrix", fontweight="bold", fontsize=12)
    plt.tight_layout()
    plt.savefig(f"{model_name.lower().replace(' ','_')}_cm.png", dpi=120, bbox_inches="tight")
    plt.show()


